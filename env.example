<!DOCTYPE html>
<html lang="he">
<head>
<meta charset="UTF-8">
<title>Football 3D</title>
<style>
* { margin:0; padding:0; box-sizing:border-box; }
html,body { width:100%; height:100%; overflow:hidden; background:#000; font-family:system-ui,sans-serif; color:#fff; }
#c { width:100%; height:100%; touch-action:none; display:block; }

#hud {
  position:fixed; top:0; left:0; right:0;
  display:flex; justify-content:center; align-items:center; gap:40px;
  padding:10px 20px;
  background:linear-gradient(to bottom,rgba(0,0,0,0.75),transparent);
  pointer-events:none; z-index:10;
}
.tscore { text-align:center; }
.tlabel { font-size:11px; color:rgba(255,255,255,0.55); letter-spacing:1px; text-transform:uppercase; }
.tnum   { font-size:50px; font-weight:700; line-height:1; }
#clock  { font-size:22px; font-weight:500; padding-top:16px; min-width:64px; text-align:center; }

/* Screens */
.screen {
  position:fixed; inset:0;
  display:flex; flex-direction:column; align-items:center; justify-content:center;
  background:rgba(0,0,0,0.88); z-index:20; gap:14px;
}
.screen h1 { font-size:36px; font-weight:700; }
.screen p  { font-size:14px; color:rgba(255,255,255,0.5); }
.screen input {
  padding:12px 18px; border-radius:8px; border:none;
  background:rgba(255,255,255,0.1); color:#fff;
  font-size:16px; width:260px; text-align:center;
  outline:none; border:1px solid rgba(255,255,255,0.2);
}
.screen input:focus { border-color:rgba(255,255,255,0.5); }
.btn {
  padding:12px 36px; border-radius:9px; border:none;
  background:#fff; color:#111; font-size:16px; font-weight:600;
  cursor:pointer; min-width:180px;
}
.btn:hover { background:#ddd; }
.btn-outline {
  background:transparent; color:#fff;
  border:1px solid rgba(255,255,255,0.3); font-size:14px;
  padding:8px 24px; border-radius:8px; cursor:pointer;
}
.btn-outline:hover { background:rgba(255,255,255,0.1); }

#status { font-size:13px; color:rgba(255,255,255,0.4); margin-top:4px; }

#goalbanner {
  position:fixed; inset:0; display:none; pointer-events:none;
  align-items:center; justify-content:center; z-index:15;
}
#goalbanner span {
  font-size:90px; font-weight:900;
  text-shadow:0 0 60px rgba(255,210,0,1);
  animation:pop .25s ease-out;
}
@keyframes pop { from{transform:scale(0.3);opacity:0} 70%{transform:scale(1.1)} to{transform:scale(1);opacity:1} }

/* Chat */
#chat {
  position:fixed; bottom:50px; left:16px;
  width:220px; z-index:10;
}
#chatlog {
  max-height:100px; overflow-y:auto;
  font-size:12px; color:rgba(255,255,255,0.6);
  margin-bottom:4px;
}
#chatinput {
  width:100%; padding:6px 10px; border-radius:6px;
  background:rgba(255,255,255,0.1); border:none; color:#fff;
  font-size:12px; outline:none;
}

#hint {
  position:fixed; bottom:10px; left:0; right:0;
  text-align:center; font-size:11px; color:rgba(255,255,255,0.25);
  pointer-events:none; z-index:10;
}
</style>
</head>
<body>
<canvas id="c"></canvas>

<!-- HUD -->
<div id="hud" style="display:none">
  <div class="tscore">
    <div class="tlabel" id="name1">שחקן 1</div>
    <div class="tnum" id="s1">0</div>
  </div>
  <div id="clock">2:00</div>
  <div class="tscore">
    <div class="tlabel" id="name2">שחקן 2</div>
    <div class="tnum" id="s2">0</div>
  </div>
</div>

<div id="goalbanner"><span>⚽ GOAL!</span></div>

<!-- Chat -->
<div id="chat" style="display:none">
  <div id="chatlog"></div>
  <input id="chatinput" placeholder="הודעה... (Enter לשלוח)" maxlength="80">
</div>

<div id="hint">🎮 Stick לזוז • B לבעוט • גלגלת לזום</div>

<!-- LOGIN SCREEN -->
<div class="screen" id="loginScreen">
  <h1>⚽ Football 3D</h1>
  <p>משחק מולטיפלייר</p>
  <input id="usernameInput" placeholder="שם משתמש" maxlength="20">
  <button class="btn" onclick="joinQueue()">חפש משחק 🎮</button>
  <button class="btn-outline" onclick="showLeaderboard()">לוח תוצאות 🏆</button>
  <p id="status"></p>
</div>

<!-- WAITING SCREEN -->
<div class="screen" id="waitScreen" style="display:none">
  <h1>🔍 מחפש יריב...</h1>
  <p id="queuePos">ממתין בתור</p>
  <div style="width:40px;height:40px;border:3px solid rgba(255,255,255,0.3);border-top-color:#fff;border-radius:50%;animation:spin 1s linear infinite;margin:10px"></div>
  <button class="btn-outline" onclick="leaveQueue()">ביטול</button>
</div>

<!-- MATCH FOUND -->
<div class="screen" id="matchScreen" style="display:none">
  <h1>✅ נמצא יריב!</h1>
  <p id="matchInfo"></p>
  <p style="font-size:24px;font-weight:700" id="countdown">3</p>
</div>

<!-- RESULT SCREEN -->
<div class="screen" id="resultScreen" style="display:none">
  <h1 id="resultTitle">תוצאה</h1>
  <p id="resultScore" style="font-size:32px;font-weight:700;margin:8px 0"></p>
  <button class="btn" onclick="joinQueue()">שחק שוב 🔄</button>
  <button class="btn-outline" onclick="showLogin()">תפריט ראשי</button>
</div>

<style>
@keyframes spin { to { transform:rotate(360deg); } }
</style>

<script src="https://cdn.babylonjs.com/babylon.js"></script>
<script src="https://cdn.babylonjs.com/cannon.js"></script>
<script src="/socket.io/socket.io.js"></script>
<script>
// ── ENGINE ────────────────────────────────────────────────────────────────────
const canvas = document.getElementById('c');
const engine = new BABYLON.Engine(canvas, true);
const scene  = new BABYLON.Scene(engine);
scene.enablePhysics(new BABYLON.Vector3(0,-9.81,0), new BABYLON.CannonJSPlugin());
scene.clearColor = new BABYLON.Color4(0.05,0.08,0.15,1);

// Camera
const cam = new BABYLON.ArcRotateCamera("cam",-Math.PI/2,Math.PI/3.5,85,BABYLON.Vector3.Zero(),scene);
cam.lowerRadiusLimit=35; cam.upperRadiusLimit=140;
cam.upperBetaLimit=Math.PI/2.1; cam.wheelPrecision=4;
cam.attachControl(canvas,true);

// Lights
const hemi=new BABYLON.HemisphericLight("h",new BABYLON.Vector3(0,1,0),scene);
hemi.intensity=0.6; hemi.groundColor=new BABYLON.Color3(0.08,0.12,0.08);
[[-57,-42],[57,-42],[57,42],[-57,42]].forEach(([x,z])=>{
  const sl=new BABYLON.SpotLight("fl"+x+z,new BABYLON.Vector3(x,42,z),
    new BABYLON.Vector3(-x*0.025,-1,-z*0.025).normalize(),Math.PI/2.6,1.1,scene);
  sl.intensity=600; sl.diffuse=new BABYLON.Color3(1,0.97,0.88);
});

// ── PITCH ─────────────────────────────────────────────────────────────────────
function box(x,y,z,w,h,d,mat,phys=false){
  const b=BABYLON.MeshBuilder.CreateBox("b"+Math.random().toFixed(5),{width:w,height:h,depth:d},scene);
  b.position.set(x,y,z); b.material=mat;
  if(phys) b.physicsImpostor=new BABYLON.PhysicsImpostor(b,BABYLON.PhysicsImpostor.BoxImpostor,{mass:0,restitution:0.4,friction:0.6},scene);
  return b;
}
function mat(hex,spec=0.05){
  const m=new BABYLON.StandardMaterial("m"+hex,scene);
  m.diffuseColor=BABYLON.Color3.FromHexString(hex);
  m.specularColor=new BABYLON.Color3(spec,spec,spec);
  return m;
}
const mG=mat("#1a7a2e"),mGd=mat("#145e22"),mL=mat("#ffffff",0.1),
      mC=mat("#5a5a62"),mS=mat("#1535a0"),mP=mat("#eeeeee",0.3),
      mT=mat("#b04810"),mN=mat("#cccccc"); mN.alpha=0.3;
const mR=mat("#444450");

const gnd=box(0,-0.1,0,200,0.2,200,mG,true); gnd.isVisible=false;
box(0,0,0,107,0.15,70,mG);
for(let i=0;i<8;i+=2) box(-52.5+(107/8)*i+(107/16),0.08,0,107/8,0.05,70,mGd);
box(0,0.08,-36,115,0.06,3.5,mT); box(0,0.08,36,115,0.06,3.5,mT);
box(-57,0.08,0,3.5,0.06,70,mT); box(57,0.08,0,3.5,0.06,70,mT);

function ln(x,y,z,w,d){ return box(x,y,z,w,0.06,d,mL); }
const ly=0.16;
ln(0,ly,-34,107,0.18); ln(0,ly,34,107,0.18);
ln(-53.5,ly,0,0.18,68); ln(53.5,ly,0,0.18,68); ln(0,ly,0,0.18,68);
[-53.5,53.5].forEach(gx=>{
  const s=gx>0?1:-1;
  ln(gx-s*8.25,ly,0,0.18,40.3); ln(gx-s*16.5,ly,-20.15,16.5,0.18);
  ln(gx-s*16.5,ly,20.15,16.5,0.18); ln(gx-s*2.75,ly,0,0.18,18.3);
  ln(gx-s*5.5,ly,-9.15,5.5,0.18); ln(gx-s*5.5,ly,9.15,5.5,0.18);
  box(gx-s*11,ly,0,0.4,0.06,0.4,mL);
});
for(let i=0;i<48;i++){
  const a1=i/48*Math.PI*2,a2=(i+1)/48*Math.PI*2;
  const seg=ln((Math.cos(a1)+Math.cos(a2))*9.15/2,ly,(Math.sin(a1)+Math.sin(a2))*9.15/2,2*9.15*Math.sin(Math.PI/48)+0.05,0.18);
  seg.rotation.y=-Math.atan2(Math.sin(a2)-Math.sin(a1),Math.cos(a2)-Math.cos(a1));
}

function makeGoal(gx){
  const s=gx>0?1:-1,r=0.09,H=2.44,W=7.32,D=2;
  [[-W/2],[W/2]].forEach(([z])=>{
    box(gx,H/2,z,r,H,r,mP,true); box(gx+s*D,H/2,z,r,H,r,mP,true);
  });
  box(gx,H,0,r,r,W,mP,true); box(gx+s*D,H,0,r,r,W,mP,true);
  box(gx+s*D/2,H,-W/2,D,r,r,mP); box(gx+s*D/2,H,W/2,D,r,r,mP);
  box(gx+s*D,H/2,0,0.06,H,W,mN); box(gx+s*D/2,H,0,D,0.06,W,mN);
  box(gx+s*D/2,H/2,-W/2,D,H,0.06,mN); box(gx+s*D/2,H/2,W/2,D,H,0.06,mN);
}
makeGoal(53.5); makeGoal(-53.5);

function wallPhys(x,y,z,w,h,d){
  const m=box(x,y,z,w,h,d,mC); m.isVisible=false;
  m.physicsImpostor=new BABYLON.PhysicsImpostor(m,BABYLON.PhysicsImpostor.BoxImpostor,{mass:0,restitution:0.4},scene);
}
wallPhys(0,2,-35.5,115,4,0.3); wallPhys(0,2,35.5,115,4,0.3);

[-1,1].forEach(side=>{
  const bz=side*46;
  for(let t=0;t<3;t++){
    const tz=bz+side*(t*6+3),th=(t+1)*5.5;
    box(0,th/2-0.1,tz,118,th,6.5,mC);
    for(let i=0;i<100;i++) box(-50+i*1.02,th+0.18,tz,0.82,0.55,0.5,mS);
  }
  box(0,18,bz+side*10,120,0.6,20,mR);
});
[-1,1].forEach(side=>{
  const bx=side*66;
  for(let t=0;t<3;t++){
    const tx=bx+side*(t*6+3),th=(t+1)*5.5;
    box(tx,th/2-0.1,0,6.5,th,78,mC);
    for(let i=0;i<70;i++) box(tx,th+0.18,-35+i*1.02,0.5,0.55,0.82,mS);
  }
  box(bx+side*10,18,0,20,0.6,80,mR);
});
[[-59,-44],[59,-44],[59,44],[-59,44]].forEach(([x,z])=>{
  box(x,19,z,1.1,38,1.1,mC); box(x,39,z,7,0.8,4,mC);
  for(let i=0;i<5;i++){
    const bm=new BABYLON.StandardMaterial("bl"+x+z+i,scene);
    bm.emissiveColor=new BABYLON.Color3(1,0.97,0.85);
    const b=BABYLON.MeshBuilder.CreateSphere("bs"+x+z+i,{diameter:0.55},scene);
    b.position.set(x+(i-2)*1.2,38.5,z); b.material=bm;
  }
});

// ── BALL ──────────────────────────────────────────────────────────────────────
const ballMesh=BABYLON.MeshBuilder.CreateSphere("ball",{diameter:0.44,segments:12},scene);
const bm2=new BABYLON.StandardMaterial("bm2",scene);
bm2.diffuseColor=new BABYLON.Color3(0.95,0.95,0.92);
bm2.specularColor=new BABYLON.Color3(0.3,0.3,0.3);
ballMesh.material=bm2;
ballMesh.physicsImpostor=new BABYLON.PhysicsImpostor(ballMesh,BABYLON.PhysicsImpostor.SphereImpostor,{mass:0.45,restitution:0.65,friction:0.5},scene);

// ── PLAYERS ───────────────────────────────────────────────────────────────────
function makePlayer(hex,name){
  const root=new BABYLON.TransformNode(name,scene);
  const cm=new BABYLON.StandardMaterial(name+"c",scene);
  cm.diffuseColor=BABYLON.Color3.FromHexString(hex);
  const sm=new BABYLON.StandardMaterial(name+"s",scene);
  sm.diffuseColor=new BABYLON.Color3(0.94,0.76,0.58);
  const body=BABYLON.MeshBuilder.CreateCapsule(name+"b",{height:1.6,radius:0.33,tessellation:8},scene);
  body.position.set(0,0.95,0); body.material=cm; body.parent=root;
  const head=BABYLON.MeshBuilder.CreateSphere(name+"h",{diameter:0.52,segments:8},scene);
  head.position.set(0,1.9,0); head.material=sm; head.parent=root;
  const dot=BABYLON.MeshBuilder.CreateSphere(name+"d",{diameter:0.2},scene);
  dot.position.set(0,2.6,0); dot.material=cm; dot.parent=root;
  return root;
}
const p1mesh=makePlayer("#3B82F6","p1");
const p2mesh=makePlayer("#EF4444","p2");
const pMeshes=[p1mesh,p2mesh];

// ── SOCKET.IO ─────────────────────────────────────────────────────────────────
const socket = io();
let myIndex = null;
let myUsername = '';
let gameActive = false;

// ── INPUT ─────────────────────────────────────────────────────────────────────
const keys={};
document.addEventListener('keydown',e=>{
  keys[e.code]=true;
  if(['Space','Enter','ArrowUp','ArrowDown','ArrowLeft','ArrowRight'].includes(e.code)) e.preventDefault();
  if(e.code==='Enter' && document.activeElement===document.getElementById('chatinput')){
    sendChat(); return;
  }
});
document.addEventListener('keyup',e=>keys[e.code]=false);
const DEAD=0.15;
let bWas=false;

function getLocalInput(){
  const gps=[...navigator.getGamepads()].filter(Boolean);
  const gp=gps[0]||null;
  let ax=0,ay=0,bDown=false;
  if(gp){
    ax=Math.abs(gp.axes[0])>DEAD?gp.axes[0]:0;
    ay=Math.abs(gp.axes[1])>DEAD?gp.axes[1]:0;
    bDown=!!(gp.buttons[1]&&gp.buttons[1].pressed);
  }
  if(!gp||(!ax&&!ay)){
    if(keys['KeyA'])ax=-1;if(keys['KeyD'])ax=1;
    if(keys['KeyW'])ay=-1;if(keys['KeyS'])ay=1;
  }
  bDown=bDown||!!keys['Space'];
  const mag=Math.hypot(ax,ay);if(mag>1){ax/=mag;ay/=mag;}
  const kick=bDown&&!bWas; bWas=bDown;
  return{ax,ay,kick};
}

// ── GAME LOOP — send input, receive state ─────────────────────────────────────
scene.registerBeforeRender(()=>{
  if(!gameActive||myIndex===null) return;
  const input=getLocalInput();
  socket.emit('player_input',input);
});

// ── SOCKET EVENTS ─────────────────────────────────────────────────────────────
socket.on('queue_status', d=>{
  document.getElementById('queuePos').textContent=`מיקום בתור: ${d.position}`;
});

socket.on('match_found', d=>{
  showScreen('matchScreen');
  document.getElementById('matchInfo').textContent=
    `${d.players[0]} מול ${d.players[1]}`;
  document.getElementById('hud').style.display='flex';
  document.getElementById('name1').textContent=d.players[0];
  document.getElementById('name2').textContent=d.players[1];
  let cd=3;
  const iv=setInterval(()=>{
    cd--;
    document.getElementById('countdown').textContent=cd||'🎮';
    if(cd<=0) clearInterval(iv);
  },1000);
});

socket.on('player_index', idx=>{
  myIndex=idx;
});

socket.on('game_start', ()=>{
  showScreen(null);
  document.getElementById('chat').style.display='block';
  gameActive=true;
});

socket.on('game_state', state=>{
  // Update ball position
  ballMesh.position.set(state.ball.x, state.ball.y||0.3, state.ball.z);
  // Update both players
  [0,1].forEach(i=>{
    const ps=state.players[i];
    if(ps) pMeshes[i].position.set(ps.x,0,ps.z);
    if(ps&&Math.hypot(ps.dx,ps.dz)>0.1)
      pMeshes[i].rotation.y=Math.atan2(ps.dx,ps.dz);
  });
});

socket.on('timer', t=>{
  const m=Math.floor(t/60),s=t%60;
  document.getElementById('clock').textContent=m+':'+(s<10?'0':'')+s;
});

socket.on('goal', d=>{
  document.getElementById('s1').textContent=d.score[0];
  document.getElementById('s2').textContent=d.score[1];
  const b=document.getElementById('goalbanner');
  b.style.display='flex';
  setTimeout(()=>b.style.display='none',2500);
});

socket.on('match_end', d=>{
  gameActive=false;
  const s=d.score;
  const me=myIndex, opp=1-myIndex;
  const won=s[me]>s[opp];
  document.getElementById('resultTitle').textContent=won?'ניצחת! 🏆':'הפסדת 😔';
  if(s[0]===s[1]) document.getElementById('resultTitle').textContent='תיקו! 🤝';
  document.getElementById('resultScore').textContent=s[0]+' - '+s[1];
  showScreen('resultScreen');
  document.getElementById('chat').style.display='none';
});

socket.on('opponent_left', ()=>{
  gameActive=false;
  alert('היריב עזב את המשחק');
  showScreen('loginScreen');
});

socket.on('chat', d=>{
  const log=document.getElementById('chatlog');
  log.innerHTML+=`<div><b>${d.from}:</b> ${d.text}</div>`;
  log.scrollTop=log.scrollHeight;
});

// ── UI FUNCTIONS ──────────────────────────────────────────────────────────────
function showScreen(id){
  ['loginScreen','waitScreen','matchScreen','resultScreen'].forEach(s=>{
    document.getElementById(s).style.display=s===id?'flex':'none';
  });
}

function joinQueue(){
  const u=document.getElementById('usernameInput')?.value?.trim()||'Guest';
  if(!u){ document.getElementById('status').textContent='הכנס שם משתמש'; return; }
  myUsername=u;
  socket.emit('join_queue',{username:u});
  showScreen('waitScreen');
}

function leaveQueue(){
  socket.disconnect();
  socket.connect();
  showScreen('loginScreen');
}

function showLogin(){
  gameActive=false;
  document.getElementById('hud').style.display='none';
  document.getElementById('chat').style.display='none';
  showScreen('loginScreen');
}

async function showLeaderboard(){
  const res=await fetch('/api/leaderboard');
  const data=await res.json();
  alert('🏆 לוח תוצאות:\n\n'+data.map((p,i)=>`${i+1}. ${p.username} — ${p.wins} ניצחונות`).join('\n'));
}

function sendChat(){
  const inp=document.getElementById('chatinput');
  if(inp.value.trim()) socket.emit('chat',{text:inp.value.trim()});
  inp.value='';
}

// Start with login screen
showScreen('loginScreen');
engine.runRenderLoop(()=>scene.render());
window.addEventListener('resize',()=>engine.resize());
</script>
</body>
</html>
